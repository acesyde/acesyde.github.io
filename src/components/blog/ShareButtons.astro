---
interface Props {
	title: string;
	url: string;
	description?: string;
}

const { title, url, description } = Astro.props;

const tweetText = description ? `${title} — ${description}` : title;
const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(
	tweetText,
)}&url=${encodeURIComponent(url)}`;
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(
	url,
)}`;
// Bluesky and Mastodon only take a single text field, so the URL is appended.
const socialText = `${tweetText}\n\n${url}`;
// Bluesky caps posts at 300 characters, so keep its text to title + URL.
const blueskyText = `${title}\n\n${url}`;
const blueskyHref = `https://bsky.app/intent/compose?text=${encodeURIComponent(blueskyText)}`;
// Mastodon's official share tool resolves the reader's instance in-browser.
const mastodonHref = `https://share.joinmastodon.org/?text=${encodeURIComponent(socialText)}`;
---

<div class="share">
	<span class="share-label">Share</span>
	<div class="share-buttons">
		<a
			class="share-btn"
			href={twitterHref}
			target="_blank"
			rel="noopener"
			aria-label="Share on X (Twitter)"
		>
			<svg
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M4 4l7.5 9.5L4.5 20H7l5.5-5.5L17 20h3l-7.8-9.9L19.5 4H17l-4.8 5.2L8 4H4z"></path>
			</svg>
			<span>X</span>
		</a>

		<a
			class="share-btn"
			href={linkedinHref}
			target="_blank"
			rel="noopener"
			aria-label="Share on LinkedIn"
		>
			<svg
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="3" y="3" width="18" height="18" rx="2"></rect>
				<line x1="8" y1="10" x2="8" y2="17"></line>
				<circle cx="8" cy="7" r="0.6" fill="currentColor"></circle>
				<path d="M12 17v-4a2 2 0 0 1 4 0v4"></path>
				<line x1="12" y1="10" x2="12" y2="17"></line>
			</svg>
			<span>LinkedIn</span>
		</a>

		<a
			class="share-btn"
			href={blueskyHref}
			target="_blank"
			rel="noopener"
			aria-label="Share on Bluesky"
		>
			<svg
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="currentColor"
			>
				<path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"></path>
			</svg>
			<span>Bluesky</span>
		</a>

		<a
			class="share-btn"
			href={mastodonHref}
			target="_blank"
			rel="noopener"
			aria-label="Share on Mastodon"
		>
			<svg
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="currentColor"
			>
				<path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"></path>
			</svg>
			<span>Mastodon</span>
		</a>

		<button
			class="share-btn share-copy"
			type="button"
			data-share-copy
			data-url={url}
			aria-label="Copy link"
		>
			<svg
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="9" y="9" width="11" height="11" rx="2"></rect>
				<path d="M5 15V6a2 2 0 0 1 2-2h9"></path>
			</svg>
			<span class="share-copy-label">Link</span>
		</button>
	</div>
</div>

<style>
	.share {
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
		max-width: var(--reading-width);
		margin: 48px 0 0;
	}
	.share-label {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
	}
	.share-buttons {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.share-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: hsl(var(--theme-accent));
		background: var(--accent-soft);
		padding: 4px 10px;
		border: 1px solid transparent;
		border-radius: 999px;
		cursor: pointer;
		text-decoration: none;
		line-height: 1.4;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}
	.share-btn:hover,
	.share-btn:focus-visible {
		color: hsl(var(--theme-bg));
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}
	.share-btn:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}
	.share-btn svg {
		display: inline-block;
		flex-shrink: 0;
	}
	.share-copy[data-copied="true"] {
		background: hsl(var(--theme-accent));
		color: hsl(var(--theme-bg));
		border-color: hsl(var(--theme-accent));
	}

	@media (max-width: 420px) {
		.share { gap: 10px; }
		.share-btn { padding: 4px 8px; font-size: 10.5px; }
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>("[data-share-copy]").forEach((btn) => {
		const label = btn.querySelector<HTMLElement>(".share-copy-label");
		const original = label?.textContent ?? "Copy link";
		const originalAria = btn.getAttribute("aria-label") ?? "Copy link";

		btn.addEventListener("click", async () => {
			const url = btn.dataset.url ?? window.location.href;
			try {
				// Clipboard API is available in any secure context (HTTPS / localhost).
				await navigator.clipboard.writeText(url);
			} catch {
				return;
			}
			btn.dataset.copied = "true";
			btn.setAttribute("aria-label", "Copied");
			if (label) label.textContent = "Copied!";
			setTimeout(() => {
				delete btn.dataset.copied;
				btn.setAttribute("aria-label", originalAria);
				if (label) label.textContent = original;
			}, 1500);
		});
	});
</script>
